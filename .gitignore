__pycache__/
*.pyc
*.egg-info/
.eggs/
dist/
build/

# Node
frontend/node_modules/
frontend/dist/

# 环境变量
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Conda
.conda/

